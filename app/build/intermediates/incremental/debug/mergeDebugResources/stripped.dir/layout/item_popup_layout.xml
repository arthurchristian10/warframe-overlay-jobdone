<?xml version="1.0" encoding="utf-8"?>
<!--
  Width is set to WRAP_CONTENT so the service can force a pixel width at runtime
  (screenWidth / 4 minus margins), making 4 cards fit side-by-side on any screen.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/popup_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EE0D0D20"
    android:padding="8dp"
    android:elevation="12dp">

    <!-- Item name — truncates if too long -->
    <TextView
        android:id="@+id/popup_item_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFEEDDFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="4dp" />

    <!-- Accent divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#4400E676"
        android:layout_marginBottom="4dp" />

    <!-- 48h sell price label -->
    <TextView
        android:id="@+id/popup_plat_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/forty_eight_h_sell"
        android:textColor="#FF888899"
        android:textSize="11sp"
        android:fontFamily="monospace" />

    <!-- 48h sell price value -->
    <TextView
        android:id="@+id/popup_plat_price"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#FF80FF80"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="4dp" />

    <!-- Ducat value label -->
    <TextView
        android:id="@+id/popup_ducat_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ducats"
        android:textColor="#FF888899"
        android:textSize="11sp"
        android:fontFamily="monospace" />

    <!-- Ducat value -->
    <TextView
        android:id="@+id/popup_ducat_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#FFFFCC44"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="4dp" />

    <!-- Ducat / plat ratio label -->
    <TextView
        android:id="@+id/popup_ratio_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dp_ratio"
        android:textColor="#FF888899"
        android:textSize="11sp"
        android:fontFamily="monospace" />

    <!-- Ducat / plat ratio value -->
    <TextView
        android:id="@+id/popup_ratio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textColor="#FFAADDFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="2dp" />

    <!-- Status / loading -->
    <TextView
        android:id="@+id/popup_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/loading"
        android:textColor="#FF666677"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:visibility="visible" />

</LinearLayout>
