<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start">

    <!-- ── Header card ── -->
    <LinearLayout
        android:id="@+id/toggle_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC0A0A1A"
        android:paddingHorizontal="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp"
        android:elevation="10dp">

        <!-- Row 1: green scan button + label (DEACTIVATED - kept for reference) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/btn_toggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_play"
                android:background="@drawable/circle_background"
                android:padding="10dp"
                android:elevation="8dp"
                android:contentDescription="@string/searching" />

            <TextView
                android:id="@+id/tv_toggle_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/scan_off"
                android:textColor="#FF888888"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Row 2: cog (crop) + blue cracking button + label -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageView
                android:id="@+id/btn_crop_settings"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:padding="3dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@string/confirm_crop_region" />

            <ImageView
                android:id="@+id/btn_lookup"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_search"
                android:background="@drawable/circle_background_blue"
                android:padding="10dp"
                android:elevation="8dp"
                android:contentDescription="@string/start_overlay" />

            <TextView
                android:id="@+id/tv_lookup_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/cracking_off"
                android:textColor="#FF4488FF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Row 3: debug OCR toggle button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <ImageView
                android:id="@+id/btn_debug_toggle"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_info_details"
                android:padding="3dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@string/ocr_debug" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ocr_debug"
                android:textColor="#FF666688"
                android:textSize="11sp"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Row 4: last scan timestamp -->
        <TextView
            android:id="@+id/tv_last_scan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="#FF555566"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:visibility="gone" />

    </LinearLayout>

    <!-- "48h median" subtitle -->
    <TextView
        android:id="@+id/tv_median_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginStart="4dp"
        android:text="@string/median_48h"
        android:textColor="#FF666688"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="2dp"
        android:background="#33FFFFFF"
        android:visibility="gone" />

    <!-- Scrollable results -->
    <ScrollView
        android:id="@+id/scroll_results"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:minWidth="140dp"
        android:maxWidth="260dp"
        android:maxHeight="350dp"
        android:visibility="gone"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/results_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#DD0A0A1A"
            android:padding="4dp" />

    </ScrollView>

</LinearLayout>
